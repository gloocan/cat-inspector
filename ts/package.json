{
	"name": "@gloocan/cat-inspector",
	"version": "0.1.0",
	"description": "TypeScript @Cat decorator, Return() paths, AST metadata, WebSocket inspector",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./socket-io": {
			"types": "./dist/transport/socket-io.d.ts",
			"import": "./dist/transport/socket-io.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"clean": "rm -rf dist",
		"prepublishOnly": "npm run build",
		"test": "npm run typecheck && vitest run"
	},
	"keywords": [
		"typescript",
		"decorators",
		"inspector",
		"websocket"
	],
	"license": "MIT",
	"dependencies": {
		"ajv": "^8.18.0",
		"reflect-metadata": "^0.2.2",
		"ws": "^8.18.0"
	},
	"peerDependencies": {
		"express": ">=4.18.0",
		"minio": ">=8.0.0",
		"socket.io": ">=4.8.0"
	},
	"peerDependenciesMeta": {
		"minio": {
			"optional": true
		},
		"socket.io": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/express": "^4.17.22",
		"@types/node": "^22.10.0",
		"@types/ws": "^8.5.13",
		"express": "^4.21.2",
		"minio": "^8.0.7",
		"socket.io": "^4.8.1",
		"typescript": "~5.7.0",
		"vitest": "^3.0.5"
	}
}
